{
  "manifest_version": 3,
  "name": "SnappyConnect Click-to-Call",
  "version": "1.0.0",
  "description": "Detects phone numbers on web pages and calls them through SnappyConnect.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["http://localhost:4000/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SnappyConnect"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
