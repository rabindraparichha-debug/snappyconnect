# Server
PORT=4000
# Web app base URL (used to build dial links for the Chrome extension)
WEB_APP_URL=http://localhost:3000

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=snappyconnect
# Auto-create tables. Disable in production and use migrations.
DATABASE_SYNCHRONIZE=true

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d

# Encryption key for provider credentials stored in the settings table (any string; hashed to a 256-bit key)
SETTINGS_ENCRYPTION_KEY=change-me-too

# Initial admin (created on first boot if no admin exists)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@snappyconnect.local
ADMIN_PASSWORD=admin123
